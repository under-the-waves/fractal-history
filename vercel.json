{
  "functions": {
    "api/generate-narrative.js": { "maxDuration": 60 },
    "api/generate-anchors.js": { "maxDuration": 60 },
    "api/generate-flashcards.js": { "maxDuration": 30 },
    "api/fact-check-narrative.js": { "maxDuration": 60 },
    "api/cron-decay-scores.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron-decay-scores", "schedule": "0 4 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
